FROM node:20-alpine
WORKDIR /app
# Copy both package.json and package-lock.json to leverage Docker layer cache
COPY apps/rockwell-connector/package*.json ./
RUN npm ci --omit=dev --no-audit --no-fund
COPY apps/rockwell-connector/src ./src
ENV NODE_ENV=production
EXPOSE 8100
CMD ["node", "src/index.js"]