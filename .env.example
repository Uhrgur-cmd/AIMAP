# ── Database ──────────────────────────────────────────────────
DATABASE_URL=postgresql://ctgate:ctgate@localhost:5432/ctgate

# ── AI Providers (at least one required for AI mapping) ───────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
OLLAMA_BASE_URL=http://localhost:11434

# ── Collector ─────────────────────────────────────────────────
BACKEND_URL=http://localhost:3000
POLL_INTERVAL_MS=10000

# MQTT output (leave empty to print to stdout)
MQTT_BROKER=
MQTT_TOPIC_PREFIX=ctgate

# ── Connector ports (override if needed) ──────────────────────
SIEMENS_S7_PORT=8300
SIEMENS_OPC_PORT=8301
ROCKWELL_PORT=8302
