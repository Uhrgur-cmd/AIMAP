DATABASE_URL=postgresql://aimap:aimap@localhost:5432/aimap
PORT=3000

# Existing PLC Connectors
SIEMENS_S7_URL=http://localhost:8300
SIEMENS_OPCUA_URL=http://localhost:8200
ROCKWELL_URL=http://localhost:8100

# AI Mapping – set AI_PROVIDER to 'openai', 'anthropic', or 'ollama'
AI_PROVIDER=ollama

# Cloud APIs (optional – set key + change AI_PROVIDER to use)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
ANTHROPIC_API_KEY=

# Local Ollama (default)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# File uploads
UPLOAD_PATH=./uploads

# Output pipeline
MQTT_BROKER=mqtt://localhost:1883
